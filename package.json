    "jose": "^4.14.4",
    "lerna": "^9.0.7",
    "lint-staged": "^16.2.1",
    "msw": "^2.15.0",
    "next": "^16.2.10",
    "nodemon": "^3.1.14",
    "prettier": "3.0.0",
    "query-string": "^9.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router": "^8.2.0",
    "react-transition-group": "^4.4.5",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "react-window-infinite-loader": "^2.0.1",
    "redux": "^5.0.1",
    "redux-saga": "^1.5.0",
    "reflect-metadata": "^0.2.2",
    "regenerator-runtime": "0.14.1",
    "rfc4648": "^1.5.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-import-css": "^4.2.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "serve": "^14.2.0",
    "source-map-explorer": "^2.5.3",
    "styled-components": "^6.4.3",
    "surge": "^0.31.1",
    "text-encoding-shim": "^1.0.5",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "overrides": {
    "nanoid": "3.3.16",
    "postcss": "8.5.19",
    "lerna": {
      "js-yaml": "^4.2.0",
      "tar": "^7.5.16"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
