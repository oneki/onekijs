{
  "name": "onekijs-ui",
  "private": false,
  "version": "1.0.1",
  "description": "Advanced React Web Components",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "dist/index.module.js",
  "unpkg": "dist/index.umd.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --emitDeclarationOnly --incremental false && rollup --config rollup.config.js",
    "start": "rollup -w --config rollup.config.js"
  },
  "author": "Oneki",
  "license": "MIT",
  "dependencies": {
    "@clr/city": "^1.1.0",
    "@floating-ui/react": "^0.27.20",
    "@popperjs/core": "^2.11.8",
    "@reach/observe-rect": "^1.2.0",
    "onekijs-framework": "^1.0.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "react-window-infinite-loader": "^2.0.1",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "rollup": "^4.62.2"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "sideEffects": false,
  "gitHead": "97569ff810eb1afad90c7df70bf52f04a7066132"
}
