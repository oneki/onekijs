{
  "name": "onekijs-next",
  "version": "1.0.0",
  "description": "Opiniated React framework built on top of Next.js",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "dist/index.module.js",
  "unpkg": "dist/index.umd.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --emitDeclarationOnly --incremental false && rollup --config rollup.config.js",
    "start": "rollup -w --config rollup.config.js"
  },
  "author": "Oneki",
  "license": "MIT",
  "dependencies": {
    "onekijs-framework": "^1.0.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2"
  },
  "peerDependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "sideEffects": false,
  "gitHead": "edb06e2c862c07ff7ec19f5711a3d71664126638"
}
