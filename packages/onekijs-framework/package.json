{
  "name": "onekijs-framework",
  "author": "Oneki",
  "version": "1.0.1",
  "description": "Opiniated React framework built on top of Redux and React Router v6",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.modern.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "dist/index.modern.js",
  "unpkg": "dist/index.umd.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --emitDeclarationOnly --incremental false && rollup --config rollup.config.js",
    "start": "rollup -w --config rollup.config.js"
  },
  "license": "MIT",
  "dependencies": {
    "history": "^5.3.0",
    "immer": "^11.1.11",
    "query-string": "^9.4.1",
    "react-redux": "^9.3.0",
    "react-transition-group": "^4.4.5",
    "redux": "^5.0.1",
    "redux-saga": "^1.5.0",
    "reflect-metadata": "^0.2.2",
    "rfc4648": "^1.5.4",
    "text-encoding-shim": "^1.0.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.0",
    "concurrently": "^10.0.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "sideEffects": false,
  "gitHead": "edb06e2c862c07ff7ec19f5711a3d71664126638"
}
