{
  "name": "onekijs-theme-clarity",
  "private": false,
  "version": "1.0.2",
  "description": "Opiniated React framework built on top of Next.js",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./font.css": {
      "import": "./src/font.css",
      "require": "./src/font.css"
    },
    "./next": {
      "import": "./dist/next.module.js",
      "require": "./dist/next.js"
    }
  },
  "module": "dist/index.module.js",
  "unpkg": "dist/index.umd.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --emitDeclarationOnly --incremental false && rollup --config rollup.config.js",
    "start": "rollup -w --config rollup.config.js"
  },
  "author": "Oneki",
  "license": "MIT",
  "dependencies": {
    "@clr/city": "^1.1.0",
    "onekijs-ui": "^1.0.2"
  },
  "devDependencies": {
    "rollup": "^4.62.2"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "sideEffects": false,
  "gitHead": "97569ff810eb1afad90c7df70bf52f04a7066132"
}
